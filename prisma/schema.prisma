generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ───────────────────────────────────────────────────────────────────

enum Role {
  ADMIN
  PFLEGEKRAFT
  ANGEHOERIGE
  ARZT
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum PatientStatus {
  AKTIV
  PAUSIERT
  ENTLASSEN
}

enum Pflegegrad {
  PG1
  PG2
  PG3
  PG4
  PG5
}

enum Bewusstsein {
  WACH
  SCHLAEFRIG
  SOMNOLENT
  KOMATOEES
}

enum Beatmungsmodus {
  CPAP
  BIPAP
  IPPV
  ASB
  SPONTAN
}

enum IncidentSeverity {
  NIEDRIG
  MITTEL
  HOCH
  KRITISCH
}

enum IncidentStatus {
  OFFEN
  IN_BEARBEITUNG
  GESCHLOSSEN
}

enum MedicationRoute {
  ORAL
  INHALATIV
  INTRAVENOES
  SUBKUTAN
  SONDE
  TOPISCH
}

enum AlertLevel {
  GRUEN
  GELB
  ROT
}

enum Schicht {
  TAG
  NACHT
}

enum Bewusstseinsstatus {
  WACH
  SCHLAEFRIG
  SOMNOLENT
  KOMATOEES
}

enum LagerungsTyp {
  RUECKENLAGE
  GRAD_30
  GRAD_45
  SEITENLAGE_L
  SEITENLAGE_R
}

enum TrachealSekret {
  KLAR
  GELBLICH
  GRUENLICH
  BLUTIG
}

// ─── MODELS ──────────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      Role     @default(PFLEGEKRAFT)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  staff         Staff?
  assignedTasks TaskAssignment[]
  activityLogs  ActivityLog[]
  tokens        RefreshToken[]

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("refresh_tokens")
}

model Staff {
  id         String    @id @default(cuid())
  userId     String    @unique
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobTitle   String
  phone      String?
  address    String?
  startDate  DateTime?
  locationId String?
  location   Location? @relation(fields: [locationId], references: [id])
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@map("staff")
}

model Task {
  id          String       @id @default(cuid())
  title       String
  description String?
  status      TaskStatus   @default(PENDING)
  priority    TaskPriority @default(MEDIUM)
  dueDate     DateTime?
  createdById String
  locationId  String?
  location    Location?    @relation(fields: [locationId], references: [id])
  assignments TaskAssignment[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@map("tasks")
}

model TaskAssignment {
  id        String   @id @default(cuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([taskId, userId])
  @@map("task_assignments")
}

model Location {
  id        String   @id @default(cuid())
  name      String
  address   String?
  phone     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  staff    Staff[]
  tasks    Task[]
  patients Patient[]

  @@map("locations")
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action    String
  entity    String?
  entityId  String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@map("activity_logs")
}

model Escalation {
  id          String    @id @default(cuid())
  title       String
  description String
  severity    String    @default("MEDIUM")
  status      String    @default("OPEN")
  resolvedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("escalations")
}

// ─── PHASE 2 ─────────────────────────────────────────────────────────────────

model Patient {
  id                 String        @id @default(cuid())
  vorname            String
  nachname           String
  geburtsdatum       DateTime
  diagnoseHaupt      String
  beatmungspflichtig Boolean       @default(false)
  tracheostoma       Boolean       @default(false)
  tracheostomaTyp    String?
  pflegegrad         Pflegegrad    @default(PG3)
  kostentraeger      String?
  notfallkontaktName String?
  notfallkontaktTel  String?
  adresse            String
  locationId         String?
  location           Location?     @relation(fields: [locationId], references: [id])
  aufnahmedatum      DateTime      @default(now())
  entlassdatum       DateTime?
  status             PatientStatus @default(AKTIV)
  bemerkungen        String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  carePlans         CarePlan[]
  incidents         Incident[]
  medications       Medication[]
  monitoringEntries MonitoringEntry[]
  monitoringAlerts  MonitoringAlert[]

  @@map("patients")
}

model CarePlan {
  id                 String          @id @default(cuid())
  patientId          String
  patient            Patient         @relation(fields: [patientId], references: [id], onDelete: Cascade)
  titel              String
  beschreibung       String?
  beatmungsmodus     Beatmungsmodus?
  atemzugvolumen     Int?
  peep               Float?
  fio2               Float?
  atemfrequenzGeraet Int?
  pflegeziele        String?
  massnahmen         String?
  besonderheiten     String?
  gueltigAb          DateTime        @default(now())
  gueltigBis         DateTime?
  isActive           Boolean         @default(true)
  createdById        String
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  @@map("care_plans")
}

model Incident {
  id                  String           @id @default(cuid())
  patientId           String
  patient             Patient          @relation(fields: [patientId], references: [id], onDelete: Cascade)
  reportedById        String
  titel               String
  beschreibung        String
  severity            IncidentSeverity @default(MITTEL)
  status              IncidentStatus   @default(OFFEN)
  geraetebeteiligt    Boolean          @default(false)
  geraetBezeichnung   String?
  massnahmenErgriffen String?
  mdkMeldepflichtig   Boolean          @default(false)
  mdkGemeldetAt       DateTime?
  occurredAt          DateTime
  resolvedAt          DateTime?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  @@map("incidents")
}

model Medication {
  id               String          @id @default(cuid())
  patientId        String
  patient          Patient         @relation(fields: [patientId], references: [id], onDelete: Cascade)
  prescribedById   String?
  wirkstoff        String
  handelsname      String?
  staerke          String
  darreichungsform String?
  route            MedicationRoute @default(ORAL)
  dosierung        String
  haeufigkeit      String
  isBtm            Boolean         @default(false)
  btmNummer        String?
  isInhalativum    Boolean         @default(false)
  anweisung        String?
  startDatum       DateTime        @default(now())
  endDatum         DateTime?
  isActive         Boolean         @default(true)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@map("medications")
}

// ─── PHASE 3 ─────────────────────────────────────────────────────────────────

model MonitoringEntry {
  id                     String             @id @default(cuid())
  patientId              String
  patient                Patient            @relation(fields: [patientId], references: [id], onDelete: Cascade)
  recordedById           String
  recordedAt             DateTime
  herzfrequenz           Int
  atemfrequenz           Int
  blutdruckSys           Int
  blutdruckDia           Int
  spo2                   Float
  temperatur             Float
  bewusstsein            Bewusstseinsstatus
  beatmungsmodus         Beatmungsmodus
  atemzugvolumen         Int?
  peep                   Float?
  fio2                   Float?
  spitzendruck           Float?
  trachealSekret         TrachealSekret?
  absaugungDurchgefuehrt Boolean            @default(false)
  cuffDruck              Float?
  lagerung               LagerungsTyp
  lagerungswechsel       Boolean            @default(false)
  ernaehrung             String?
  ausscheidung           String?
  bemerkungen            String?
  alertLevel             AlertLevel         @default(GRUEN)
  alertTriggered         Boolean            @default(false)
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt

  alerts MonitoringAlert[]

  @@map("monitoring_entries")
}

model MonitoringAlert {
  id               String          @id @default(cuid())
  patientId        String
  patient          Patient         @relation(fields: [patientId], references: [id], onDelete: Cascade)
  entryId          String
  entry            MonitoringEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  parameter        String
  wert             String
  schwellenwert    String
  alertLevel       AlertLevel
  acknowledgedAt   DateTime?
  acknowledgedById String?
  createdAt        DateTime        @default(now())

  @@map("monitoring_alerts")
}
