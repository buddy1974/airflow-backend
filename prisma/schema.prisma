generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ───────────────────────────────────────────────────────────────────

enum Role {
  ADMIN
  PFLEGEKRAFT
  ANGEHOERIGE
  ARZT
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum PatientStatus {
  AKTIV
  PAUSIERT
  ENTLASSEN
}

enum Pflegegrad {
  PG1
  PG2
  PG3
  PG4
  PG5
}

enum Bewusstsein {
  WACH
  SCHLAEFRIG
  SOMNOLENT
  KOMATOEES
}

enum Beatmungsmodus {
  CPAP
  BIPAP
  IPPV
  ASB
  SPONTAN
}

enum IncidentSeverity {
  NIEDRIG
  MITTEL
  HOCH
  KRITISCH
}

enum IncidentStatus {
  OFFEN
  IN_BEARBEITUNG
  GESCHLOSSEN
}

enum MedicationRoute {
  ORAL
  INHALATIV
  INTRAVENOES
  SUBKUTAN
  SONDE
  TOPISCH
}

enum AlertLevel {
  GRUEN
  GELB
  ROT
}

enum Schicht {
  TAG
  NACHT
}

enum Bewusstseinsstatus {
  WACH
  SCHLAEFRIG
  SOMNOLENT
  KOMATOEES
}

enum LagerungsTyp {
  RUECKENLAGE
  GRAD_30
  GRAD_45
  SEITENLAGE_L
  SEITENLAGE_R
}

enum TrachealSekret {
  KLAR
  GELBLICH
  GRUENLICH
  BLUTIG
}

// ─── MODELS ──────────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      Role     @default(PFLEGEKRAFT)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  staff               Staff?
  assignedTasks       TaskAssignment[]
  activityLogs        ActivityLog[]
  tokens              RefreshToken[]
  payrollRecords      PayrollRecord[]
  shifts              Shift[]
  trainingRecords     TrainingRecord[]
  staffDocuments      StaffDocument[]
  urlaubAntraege      UrlaubAntrag[]
  krankmeldungen      Krankmeldung[]
  qualifikationen     Qualifikation[]
  personalAkte        PersonalAkte?
  angehoerigerAccess  AngehoerigerAccess[]

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("refresh_tokens")
}

model Staff {
  id         String    @id @default(cuid())
  userId     String    @unique
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobTitle   String
  phone      String?
  address    String?
  startDate  DateTime?
  locationId String?
  location   Location? @relation(fields: [locationId], references: [id])
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@map("staff")
}

model Task {
  id          String       @id @default(cuid())
  title       String
  description String?
  status      TaskStatus   @default(PENDING)
  priority    TaskPriority @default(MEDIUM)
  dueDate     DateTime?
  createdById String
  locationId  String?
  location    Location?    @relation(fields: [locationId], references: [id])
  assignments TaskAssignment[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@map("tasks")
}

model TaskAssignment {
  id        String   @id @default(cuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([taskId, userId])
  @@map("task_assignments")
}

model Location {
  id        String   @id @default(cuid())
  name      String
  address   String?
  phone     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  staff    Staff[]
  tasks    Task[]
  patients Patient[]
  devices  Device[]

  @@map("locations")
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action    String
  entity    String?
  entityId  String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@map("activity_logs")
}

model Escalation {
  id          String    @id @default(cuid())
  title       String
  description String
  severity    String    @default("MEDIUM")
  status      String    @default("OPEN")
  resolvedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("escalations")
}

// ─── PHASE 2 ─────────────────────────────────────────────────────────────────

model Patient {
  id                 String        @id @default(cuid())
  vorname            String
  nachname           String
  geburtsdatum       DateTime
  diagnoseHaupt      String
  beatmungspflichtig Boolean       @default(false)
  tracheostoma       Boolean       @default(false)
  tracheostomaTyp    String?
  pflegegrad         Pflegegrad    @default(PG3)
  kostentraeger      String?
  notfallkontaktName String?
  notfallkontaktTel  String?
  adresse            String
  locationId         String?
  location           Location?     @relation(fields: [locationId], references: [id])
  aufnahmedatum      DateTime      @default(now())
  entlassdatum       DateTime?
  status             PatientStatus @default(AKTIV)
  bemerkungen        String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  carePlans          CarePlan[]
  incidents          Incident[]
  medications        Medication[]
  monitoringEntries  MonitoringEntry[]
  monitoringAlerts   MonitoringAlert[]
  devices            Device[]
  handovers          Handover[]
  invoices           Invoice[]
  shifts             Shift[]
  angehoerigerAccess AngehoerigerAccess[]
  familyMessages     FamilyMessage[]

  @@map("patients")
}

model CarePlan {
  id                 String          @id @default(cuid())
  patientId          String
  patient            Patient         @relation(fields: [patientId], references: [id], onDelete: Cascade)
  titel              String
  beschreibung       String?
  beatmungsmodus     Beatmungsmodus?
  atemzugvolumen     Int?
  peep               Float?
  fio2               Float?
  atemfrequenzGeraet Int?
  pflegeziele        String?
  massnahmen         String?
  besonderheiten     String?
  gueltigAb          DateTime        @default(now())
  gueltigBis         DateTime?
  isActive           Boolean         @default(true)
  createdById        String
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  @@map("care_plans")
}

model Incident {
  id                  String           @id @default(cuid())
  patientId           String
  patient             Patient          @relation(fields: [patientId], references: [id], onDelete: Cascade)
  reportedById        String
  titel               String
  beschreibung        String
  severity            IncidentSeverity @default(MITTEL)
  status              IncidentStatus   @default(OFFEN)
  geraetebeteiligt    Boolean          @default(false)
  geraetBezeichnung   String?
  massnahmenErgriffen String?
  mdkMeldepflichtig   Boolean          @default(false)
  mdkGemeldetAt       DateTime?
  occurredAt          DateTime
  resolvedAt          DateTime?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  @@map("incidents")
}

model Medication {
  id               String          @id @default(cuid())
  patientId        String
  patient          Patient         @relation(fields: [patientId], references: [id], onDelete: Cascade)
  prescribedById   String?
  wirkstoff        String
  handelsname      String?
  staerke          String
  darreichungsform String?
  route            MedicationRoute @default(ORAL)
  dosierung        String
  haeufigkeit      String
  isBtm            Boolean         @default(false)
  btmNummer        String?
  isInhalativum    Boolean         @default(false)
  anweisung        String?
  startDatum       DateTime        @default(now())
  endDatum         DateTime?
  isActive         Boolean         @default(true)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@map("medications")
}

// ─── PHASE 4 ─────────────────────────────────────────────────────────────────

enum DeviceTyp {
  BEATMUNG
  ABSAUGUNG
  SAUERSTOFF
  MONITORING
  ERNAEHRUNG
  SONSTIGES
}

enum DeviceStatus {
  AKTIV
  WARTUNG
  DEFEKT
  EINGELAGERT
}

// ─── PHASE 3 ─────────────────────────────────────────────────────────────────

model MonitoringEntry {
  id                     String             @id @default(cuid())
  patientId              String
  patient                Patient            @relation(fields: [patientId], references: [id], onDelete: Cascade)
  recordedById           String
  recordedAt             DateTime
  herzfrequenz           Int
  atemfrequenz           Int
  blutdruckSys           Int
  blutdruckDia           Int
  spo2                   Float
  temperatur             Float
  bewusstsein            Bewusstseinsstatus
  beatmungsmodus         Beatmungsmodus
  atemzugvolumen         Int?
  peep                   Float?
  fio2                   Float?
  spitzendruck           Float?
  trachealSekret         TrachealSekret?
  absaugungDurchgefuehrt Boolean            @default(false)
  cuffDruck              Float?
  lagerung               LagerungsTyp
  lagerungswechsel       Boolean            @default(false)
  ernaehrung             String?
  ausscheidung           String?
  bemerkungen            String?
  alertLevel             AlertLevel         @default(GRUEN)
  alertTriggered         Boolean            @default(false)
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt

  alerts MonitoringAlert[]

  @@map("monitoring_entries")
}

model MonitoringAlert {
  id               String          @id @default(cuid())
  patientId        String
  patient          Patient         @relation(fields: [patientId], references: [id], onDelete: Cascade)
  entryId          String
  entry            MonitoringEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  parameter        String
  wert             String
  schwellenwert    String
  alertLevel       AlertLevel
  acknowledgedAt   DateTime?
  acknowledgedById String?
  createdAt        DateTime        @default(now())

  @@map("monitoring_alerts")
}

model Device {
  id                String       @id @default(cuid())
  bezeichnung       String
  hersteller        String?
  modell            String?
  seriennummer      String?      @unique
  typ               DeviceTyp
  status            DeviceStatus @default(AKTIV)
  anschaffungsdatum DateTime?
  naechsteWartung   DateTime?
  patientId         String?
  patient           Patient?     @relation(fields: [patientId], references: [id])
  locationId        String?
  location          Location?    @relation(fields: [locationId], references: [id])
  bemerkungen       String?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  checks DeviceCheck[]

  @@map("devices")
}

model DeviceCheck {
  id              String   @id @default(cuid())
  deviceId        String
  device          Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  checkedById     String
  checkedAt       DateTime @default(now())
  funktionsfaehig Boolean  @default(true)
  bemerkungen     String?
  createdAt       DateTime @default(now())

  @@map("device_checks")
}

// ─── PHASES 5, 6, 7 ──────────────────────────────────────────────────────────

enum UebergabeStatus {
  ENTWURF
  ABGESCHLOSSEN
  QUITTIERT
}

enum InvoiceStatus {
  ENTWURF
  VERSENDET
  BEZAHLT
  UEBERFAELLIG
  STORNIERT
}

enum TransactionTyp {
  EINNAHME
  AUSGABE
}

enum PayrollStatus {
  AUSSTEHEND
  GENEHMIGT
  AUSGEZAHLT
}

enum RotaStatus {
  ENTWURF
  VEROEFFENTLICHT
}

enum ShiftStatus {
  GEPLANT
  AKTIV
  ABGESCHLOSSEN
  ABWESEND
}

model Handover {
  id              String          @id @default(cuid())
  patientId       String
  patient         Patient         @relation(fields: [patientId], references: [id], onDelete: Cascade)
  schicht         Schicht
  schichtDatum    DateTime
  erstelltVonId   String
  quittiertvonId  String?
  status          UebergabeStatus @default(ENTWURF)
  zusammenfassung String
  offenePunkte    String?
  massnahmen      String?
  dringend        Boolean         @default(false)
  quittierAtAt    DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@map("handovers")
}

model Invoice {
  id                String        @id @default(cuid())
  patientId         String
  patient           Patient       @relation(fields: [patientId], references: [id])
  rechnungsnummer   String        @unique
  betrag            Float
  mwst              Float         @default(0)
  status            InvoiceStatus @default(ENTWURF)
  leistungsdatum    DateTime
  faelligkeitsdatum DateTime
  bezahltAm         DateTime?
  kostentraeger     String?
  beschreibung      String?
  createdById       String
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@map("invoices")
}

model FinanceTransaction {
  id           String         @id @default(cuid())
  typ          TransactionTyp
  betrag       Float
  beschreibung String
  kategorie    String?
  datum        DateTime
  createdById  String
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@map("finance_transactions")
}

model PayrollRecord {
  id             String        @id @default(cuid())
  userId         String
  user           User          @relation(fields: [userId], references: [id])
  monat          Int
  jahr           Int
  grundgehalt    Float
  zuschlaege     Float         @default(0)
  abzuege        Float         @default(0)
  netto          Float
  status         PayrollStatus @default(AUSSTEHEND)
  genehmigtvonId String?
  genehmigAt     DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@map("payroll_records")
}

model Rota {
  id            String     @id @default(cuid())
  wocheVom      DateTime
  wocheBis      DateTime
  status        RotaStatus @default(ENTWURF)
  erstelltVonId String
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  shifts Shift[]

  @@map("rotas")
}

model Shift {
  id          String      @id @default(cuid())
  rotaId      String
  rota        Rota        @relation(fields: [rotaId], references: [id], onDelete: Cascade)
  userId      String
  user        User        @relation(fields: [userId], references: [id])
  patientId   String
  patient     Patient     @relation(fields: [patientId], references: [id])
  schicht     Schicht
  datum       DateTime
  startzeit   DateTime
  endzeit     DateTime
  status      ShiftStatus @default(GEPLANT)
  clockInAt   DateTime?
  clockOutAt  DateTime?
  bemerkungen String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@map("shifts")
}

// ─── PHASE 8 ─────────────────────────────────────────────────────────────────

enum TrainingStatus {
  AUSSTEHEND
  ABGESCHLOSSEN
  ABGELAUFEN
}

enum ComplianceStatus {
  KONFORM
  FAELLIG
  UEBERFAELLIG
  NICHT_ANWENDBAR
}

enum RecruitmentStatus {
  EINGEGANGEN
  IN_PRUEFUNG
  EINGELADEN
  ABGELEHNT
  EINGESTELLT
}

enum DocumentTyp {
  FUEHRUNGSZEUGNIS
  AUSBILDUNGSNACHWEIS
  IMPFNACHWEIS
  ARBEITSVERTRAG
  QUALIFIKATION
  SONSTIGES
}

model TrainingRecord {
  id              String         @id @default(cuid())
  userId          String
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  bezeichnung     String
  anbieter        String?
  abgeschlossenAm DateTime?
  gueltigBis      DateTime?
  status          TrainingStatus @default(AUSSTEHEND)
  pflichtschulung Boolean        @default(false)
  zertifikatUrl   String?
  bemerkungen     String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@map("training_records")
}

model RecruitmentApplication {
  id             String            @id @default(cuid())
  vorname        String
  nachname       String
  email          String
  telefon        String?
  position       String
  status         RecruitmentStatus @default(EINGEGANGEN)
  bewerbungstext String?
  cvUrl          String?
  notizen        String?
  eingestelltAm  DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@map("recruitment_applications")
}

model ComplianceCheck {
  id            String           @id @default(cuid())
  bezeichnung   String
  beschreibung  String?
  status        ComplianceStatus @default(FAELLIG)
  faelligAm     DateTime?
  erledigtAm    DateTime?
  erledigtVonId String?
  mdkRelevant   Boolean          @default(true)
  kategorie     String?
  bemerkungen   String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@map("compliance_checks")
}

model StaffDocument {
  id                String      @id @default(cuid())
  userId            String
  user              User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  typ               DocumentTyp
  bezeichnung       String
  ausstellungsdatum DateTime?
  ablaufdatum       DateTime?
  dokumentUrl       String?
  verifiziert       Boolean     @default(false)
  bemerkungen       String?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  @@map("staff_documents")
}

// ─── PHASE 9b ────────────────────────────────────────────────────────────────

enum UrlaubStatus {
  BEANTRAGT
  GENEHMIGT
  ABGELEHNT
  STORNIERT
}

enum KrankmeldungStatus {
  AKTIV
  BEENDET
}

enum QualifikationTyp {
  BEATMUNGSPFLEGE
  TRACHEOSTOMA
  BTM_BERECHTIGUNG
  WUNDVERSORGUNG
  ERSTE_HILFE
  HYGIENE
  SONSTIGES
}

model UrlaubAntrag {
  id             String       @id @default(cuid())
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  vonDatum       DateTime
  bisDatum       DateTime
  tage           Int
  status         UrlaubStatus @default(BEANTRAGT)
  grund          String?
  genehmigtvonId String?
  genehmigAt     DateTime?
  bemerkungen    String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@map("urlaub_antraege")
}

model Krankmeldung {
  id          String             @id @default(cuid())
  userId      String
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  vonDatum    DateTime
  bisDatum    DateTime?
  status      KrankmeldungStatus @default(AKTIV)
  diagnose    String?
  attest      Boolean            @default(false)
  bemerkungen String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@map("krankmeldungen")
}

model Qualifikation {
  id          String           @id @default(cuid())
  userId      String
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  typ         QualifikationTyp
  erworbenAm  DateTime?
  gueltigBis  DateTime?
  nachweisUrl String?
  bestaetigt  Boolean          @default(false)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@map("qualifikationen")
}

model PersonalAkte {
  id              String    @id @default(cuid())
  userId          String    @unique
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  eintrittsdatum  DateTime?
  probezeitEnde   DateTime?
  vertragTyp      String?
  wochenstunden   Float?
  urlaubstageJahr Int       @default(28)
  resturlaub      Int       @default(0)
  tarifgruppe     String?
  notizen         String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@map("personal_akte")
}

// ─── PHASE 10 ────────────────────────────────────────────────────────────────

model EmailLog {
  id         String   @id @default(cuid())
  gmailId    String?  @unique
  from       String
  to         String
  subject    String
  snippet    String?
  isRead     Boolean  @default(false)
  category   String?
  receivedAt DateTime
  createdAt  DateTime @default(now())

  @@map("email_logs")
}

model GoogleToken {
  id           String   @id @default(cuid())
  userId       String   @unique
  accessToken  String
  refreshToken String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("google_tokens")
}

// ─── PHASES 12–14 ────────────────────────────────────────────────────────────

enum SocialPostStatus {
  ENTWURF
  GEPLANT
  VEROEFFENTLICHT
  FEHLGESCHLAGEN
}

model SocialPost {
  id                String           @id @default(cuid())
  titel             String
  inhalt            String
  bildUrl           String?
  status            SocialPostStatus @default(ENTWURF)
  geplantFuer       DateTime?
  veroeffentlichtAm DateTime?
  plattform         String           @default("Facebook")
  createdById       String
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@map("social_posts")
}

model AngehoerigerAccess {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  patientId String
  patient   Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  @@unique([userId, patientId])
  @@map("angehoerige_access")
}

model FamilyMessage {
  id           String   @id @default(cuid())
  patientId    String
  patient      Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  vonUserId    String
  nachricht    String
  isFromFamily Boolean  @default(true)
  gelesen      Boolean  @default(false)
  createdAt    DateTime @default(now())

  @@map("family_messages")
}
